# 1. Borramos la carpeta vendor del repositorio (sin borrarla de tu PC)
git rm -r --cached vendor

# 2. Creamos el archivo .gitignore (si no lo tienes aún)
echo "/vendor" > .gitignore
echo ".env" >> .gitignore

# 3. Guardamos este cambio
git add .gitignore
git commit -m "chore: ignorar carpeta vendor y archivos de entorno"